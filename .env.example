# Project Config
PROJECT_NAME="Enterprise SAP FI Forecasting Platform"
API_V1_STR="/api/v1"

# Database Connection (PostgreSQL-only)
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sap_fi_forecasting

# JWT Security
SECRET_KEY=supersecretjwtkeythatshouldbechangedinproduction12345
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM Providers Configuration
# Supported providers: gemini, openai
LLM_PROVIDER=gemini
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Security & Limits
RATE_LIMIT_PER_MINUTE=60
